# CareerTwin AI v2 — Environment Variables
# Copy to .env and fill in real values

# App
DEBUG=False
APP_NAME=CareerTwin AI
APP_VERSION=2.0.0

# Database
DATABASE_URL=postgresql://careertwin:careertwin123@postgres:5432/careertwin_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Gemini AI — get at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# CORS (comma-separated in production)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
